{
  "name": "coding-and-architecture-requirements",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "badge:site": "bun scripts/generate-site-badge.ts",
    "branding:assets": "bun run badge:site && bun scripts/generate-readme-badge-assets.ts",
    "branding:assets:check": "bun scripts/generate-site-badge.ts --check && bun scripts/generate-readme-badge-assets.ts --check",
    "typecheck": "tsc --noEmit",
    "test:badges": "bun test scripts/site-badge.test.ts scripts/readme-badge-assets.test.ts"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "typescript": "^5.9.3"
  }
}
